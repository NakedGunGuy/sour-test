{
    "name": "sauerkraut/app",
    "description": "Sauerkraut framework application",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "sauerkraut/ui": "@dev",
        "sauerkraut/cms": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Sauerkraut\\": "framework/",
            "App\\": "app/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/sauerkraut-ui"
        },
        {
            "type": "path",
            "url": "./packages/sauerkraut-cms"
        }
    ]
}
