{
    "name": "sauerkraut/app",
    "description": "Sauerkraut framework application",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "sauerkraut/ui": "@dev",
        "sauerkraut/cms": "@dev",
        "dragonmantank/cron-expression": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Sauerkraut\\": "framework/",
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/sauerkraut-ui"
        },
        {
            "type": "path",
            "url": "./packages/sauerkraut-cms"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
