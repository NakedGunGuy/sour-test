#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/vendor/autoload.php';

$app = \Sauerkraut\App::boot(__DIR__);

$command = $argv[1] ?? 'help';
$args = array_slice($argv, 2);

match ($command) {
    'ui:publish' => packagePublish('sauerkraut/ui', 'frontend', $args),
    'cms:publish' => packagePublish('sauerkraut/cms', 'cms', $args),
    'help' => help(),
    default => println("Unknown command: {$command}. Run 'php sauerkraut help' for available commands."),
};

/**
 * Publish files from a sauerkraut package to the project.
 *
 * @param string $packageName  e.g. "sauerkraut/ui" or "sauerkraut/cms"
 * @param string $publishTo    project-relative destination directory
 * @param array  $args         CLI arguments (component name, --all, --force)
 */
function packagePublish(string $packageName, string $publishTo, array $args): void
{
    $installed = basePath() . '/vendor/composer/installed.json';
    if (!file_exists($installed)) {
        println('Vendor directory not found. Run composer install first.');
        return;
    }

    $data = json_decode(file_get_contents($installed), true);
    $packages = $data['packages'] ?? $data;

    $pkgConfig = null;
    foreach ($packages as $package) {
        if ($package['name'] === $packageName) {
            $pkgConfig = $package;
            break;
        }
    }

    if (!$pkgConfig) {
        println("{$packageName} package not found. Run: composer require {$packageName}");
        return;
    }

    $sauerkraut = $pkgConfig['extra']['sauerkraut'] ?? [];
    $installPath = basePath() . '/vendor/' . $packageName;

    $force = in_array('--force', $args);
    $all = in_array('--all', $args);
    $target = null;
    foreach ($args as $arg) {
        if (!str_starts_with($arg, '-')) {
            $target = $arg;
            break;
        }
    }

    // Determine publishable directories based on package type
    $publishable = [];

    $componentsPath = $sauerkraut['components-path'] ?? null;
    if ($componentsPath && is_dir($installPath . '/' . $componentsPath)) {
        $dirs = glob($installPath . '/' . $componentsPath . '/*', GLOB_ONLYDIR);
        foreach ($dirs as $dir) {
            $name = basename($dir);
            $publishable['components/' . $name] = [
                'source' => $dir,
                'dest' => basePath() . '/' . $publishTo . '/components/' . $name,
                'label' => "component: {$name}",
            ];
        }
    }

    $pagesPath = $sauerkraut['pages-path'] ?? null;
    if ($pagesPath && is_dir($installPath . '/' . $pagesPath)) {
        $publishable['pages'] = [
            'source' => $installPath . '/' . $pagesPath,
            'dest' => basePath() . '/' . $publishTo . '/pages',
            'label' => 'pages',
        ];
    }

    $cssPath = $sauerkraut['css'] ?? null;
    if ($cssPath && file_exists($installPath . '/' . $cssPath)) {
        $publishable['css'] = [
            'source' => $installPath . '/' . $cssPath,
            'dest' => basePath() . '/' . $publishTo . '/' . basename($cssPath),
            'label' => 'css',
        ];
    }

    $configPath = $sauerkraut['config'] ?? null;
    if ($configPath && file_exists($installPath . '/' . $configPath)) {
        $publishable['config'] = [
            'source' => $installPath . '/' . $configPath,
            'dest' => basePath() . '/config/' . basename($configPath),
            'label' => 'config',
        ];
    }

    $routesPath = $sauerkraut['routes'] ?? null;
    if ($routesPath && file_exists($installPath . '/' . $routesPath)) {
        $publishable['routes'] = [
            'source' => $installPath . '/' . $routesPath,
            'dest' => basePath() . '/routes/' . basename($routesPath),
            'label' => 'routes',
        ];
    }

    if (empty($publishable)) {
        println("No publishable files found in {$packageName}.");
        return;
    }

    if (!$all && !$target) {
        $shortName = explode('/', $packageName)[1];
        println("Usage: php sauerkraut {$shortName}:publish <target>");
        println("       php sauerkraut {$shortName}:publish --all");
        println('');
        println('Options:');
        println('  --force    Overwrite existing files');
        println('  --all      Publish everything');
        println('');
        println('Available targets:');
        foreach ($publishable as $key => $item) {
            println("  {$key}");
        }
        return;
    }

    if ($all) {
        foreach ($publishable as $key => $item) {
            publishItem($key, $item, $force);
        }
        return;
    }

    // Find matching publishable item
    if (isset($publishable[$target])) {
        publishItem($target, $publishable[$target], $force);
        return;
    }

    // Try as a component name shorthand (e.g. "button" → "components/button")
    $componentKey = 'components/' . $target;
    if (isset($publishable[$componentKey])) {
        publishItem($componentKey, $publishable[$componentKey], $force);
        return;
    }

    println("Target '{$target}' not found in {$packageName}.");
}

function publishItem(string $key, array $item, bool $force): void
{
    $source = $item['source'];
    $dest = $item['dest'];

    if (is_dir($source)) {
        publishDir($source, $dest, $key, $force);
    } else {
        publishFile($source, $dest, $key, $force);
    }
}

function publishDir(string $source, string $dest, string $label, bool $force): void
{
    if (is_dir($dest) && !$force) {
        println("  Skipped: {$label} (already exists, use --force to overwrite)");
        return;
    }

    if (is_dir($dest)) {
        $files = new \RecursiveIteratorIterator(
            new \RecursiveDirectoryIterator($dest, \FilesystemIterator::SKIP_DOTS),
            \RecursiveIteratorIterator::CHILD_FIRST,
        );
        foreach ($files as $file) {
            $file->isDir() ? rmdir($file->getPathname()) : unlink($file->getPathname());
        }
        rmdir($dest);
    }

    mkdir($dest, 0755, true);

    $sourceFiles = new \RecursiveIteratorIterator(
        new \RecursiveDirectoryIterator($source, \FilesystemIterator::SKIP_DOTS),
    );
    foreach ($sourceFiles as $file) {
        $relative = substr($file->getPathname(), strlen($source));
        $relative = ltrim(str_replace('\\', '/', $relative), '/');
        $targetPath = "{$dest}/{$relative}";
        $targetDir = dirname($targetPath);
        if (!is_dir($targetDir)) {
            mkdir($targetDir, 0755, true);
        }
        copy($file->getPathname(), $targetPath);
    }

    println("  Published: {$label}");
}

function publishFile(string $source, string $dest, string $label, bool $force): void
{
    if (file_exists($dest) && !$force) {
        println("  Skipped: {$label} (already exists, use --force to overwrite)");
        return;
    }

    $destDir = dirname($dest);
    if (!is_dir($destDir)) {
        mkdir($destDir, 0755, true);
    }

    copy($source, $dest);
    println("  Published: {$label}");
}

function help(): void
{
    println('');
    println('Sauerkraut CLI');
    println('==============');
    println('');
    println('Usage: php sauerkraut <command> [arguments]');
    println('');
    println('Available commands:');
    println('  ui:publish           Publish vendor UI components to your project');
    println('  cms:publish          Publish vendor CMS files to your project');
    println('  help                 Show this help message');
    println('');
}

function basePath(): string
{
    return \Sauerkraut\App::getInstance()->basePath();
}

function println(string $text = ''): void
{
    echo $text . PHP_EOL;
}
