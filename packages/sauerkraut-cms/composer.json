{
    "name": "sauerkraut/cms",
    "description": "Auto-discovering CMS for the Sauerkraut framework",
    "type": "library",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "psr-4": {
            "Sauerkraut\\CMS\\": "src/"
        }
    },
    "extra": {
        "sauerkraut": {
            "components-path": "components",
            "components-prefix": "cms:",
            "components-group": "cms",
            "pages-path": "pages",
            "routes": "routes/cms.php",
            "config": "config/cms.php",
            "css": "css/cms.css"
        }
    }
}
